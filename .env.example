# Writing Hub — Environment Variables
# Copy to .env and fill in values

DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave empty for SQLite in dev)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# iil-weltenfw — WeltenHub REST Client
# https://pypi.org/project/iil-weltenfw/
WELTENHUB_URL=https://weltenforger.com/api/v1
WELTENHUB_TOKEN=your-weltenhub-api-token
WELTENHUB_LOOKUP_TTL=3600
WELTENHUB_TIMEOUT=30.0

# iil-aifw — LLM Routing (DB-driven via Django Admin)
# No env vars needed — configure AIActionType in Django Admin after:
#   python manage.py init_llm_config
# LLM provider API keys are set on LLMProvider model via env var name
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
